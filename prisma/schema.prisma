generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Publication {
  id        String   @id @default(cuid())
  title     String
  type      String
  date      String
  topic     String
  excerpt   String
  language  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaItem {
  id          String   @id @default(cuid())
  title       String
  slug        String?
  type        String
  excerpt     String?
  publishedAt String?
  image       String?
  language    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactInquiry {
  id           String   @id @default(cuid())
  name         String
  email        String
  organization String?
  interest     String?
  message      String
  locale       String
  createdAt    DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
